generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model EmailSubscriber {
  id                  String    @id @default(cuid())
  email               String    @unique
  status              String    @default("pending")
  locale              String    @default("en")
  timezone            String    @default("Asia/Kuala_Lumpur")
  preferredSendHour   Int       @default(8)
  preferredSendMinute Int       @default(0)
  note                String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  activatedAt         DateTime?
  bouncedAt           DateTime?
  lastManagedAt       DateTime?

  subscriptions      SubscriberSourceSubscription[]
  tokens             SubscriptionToken[]
  deliveries         DigestDelivery[]
  combinedDeliveries SubscriberDigestDelivery[]
}

model TrackedSource {
  id                  String    @id @default(cuid())
  slug                String    @unique
  name                String
  organizationName    String?
  description         String?
  rootUrl             String
  category            String
  adapterType         String
  sourceType          String    @default("official-website")
  automationMode      String    @default("html")
  language            String    @default("en")
  trustTier           String    @default("official")
  includeKeywordsJson String?
  excludeKeywordsJson String?
  seedUrlsJson        String?
  detailPatternsJson  String?
  timezone            String    @default("Asia/Kuala_Lumpur")
  cadence             String    @default("daily")
  isActive            Boolean   @default(true)
  isPublic            Boolean   @default(true)
  lastSuccessfulRunAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  subscriptions           SubscriberSourceSubscription[]
  sourceSubmissions       SourceSubmission[]
  deliveries              DigestDelivery[]
  combinedDeliverySources SubscriberDigestDeliverySource[]
  updates                 SourceUpdate[]
  runs                    SourceRun[]
  reviewItems             SourceReviewItem[]

  @@index([isActive, isPublic])
  @@index([category, isActive])
  @@index([sourceType, automationMode])
}

model SourceRun {
  id              String   @id @default(cuid())
  sourceId        String
  targetDate      DateTime
  adapterName     String
  status          String
  errorClass      String?
  automationLevel String?
  attemptCount    Int      @default(1)
  durationMs      Int      @default(0)
  candidateCount  Int      @default(0)
  fetchedCount    Int      @default(0)
  normalizedCount Int      @default(0)
  insertedCount   Int      @default(0)
  updatedCount    Int      @default(0)
  reviewItemCount Int      @default(0)
  notesJson       String?
  metadataJson    String?
  startedAt       DateTime @default(now())
  finishedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  source TrackedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, targetDate])
  @@index([status, targetDate])
}

model SourceReviewItem {
  id         String   @id @default(cuid())
  sourceId   String
  targetDate DateTime
  dedupeKey  String   @unique
  queueReason String
  priority   String
  summary    String
  seedUrl    String?
  detailsJson String?
  status     String   @default("open")
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  source TrackedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, targetDate])
  @@index([status, createdAt])
}

model SourceUpdate {
  id                 String   @id @default(cuid())
  sourceId           String
  slug               String
  title              String
  sourceUrl          String
  sourceUrlHash      String
  targetDate         DateTime
  publishedDate      DateTime?
  updatedDate        DateTime?
  summary            String?
  bodyText           String?
  label              String    @default("Other")
  matchedKeywordsJson String?
  isPublic           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  source TrackedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, sourceUrlHash, targetDate])
  @@unique([sourceId, slug])
  @@index([sourceId, targetDate])
  @@index([isPublic, targetDate])
}

model SubscriberSourceSubscription {
  id             String    @id @default(cuid())
  subscriberId   String
  sourceId       String
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  confirmedAt    DateTime?
  unsubscribedAt DateTime?

  subscriber EmailSubscriber     @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  source     TrackedSource       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  tokens     SubscriptionToken[]

  @@unique([subscriberId, sourceId])
  @@index([status])
  @@index([sourceId, status])
}

model SubscriptionToken {
  id             String    @id @default(cuid())
  token          String    @unique
  subscriberId   String
  subscriptionId String?
  type           String
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  consumedAt     DateTime?

  subscriber   EmailSubscriber               @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  subscription SubscriberSourceSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([type, expiresAt])
  @@index([subscriberId])
}

model DigestDelivery {
  id            String    @id @default(cuid())
  sourceId      String
  subscriberId  String
  targetDate    DateTime
  status        String    @default("scheduled")
  subject       String
  emailId       String?
  itemCount     Int       @default(0)
  summary       String?
  failureReason String?
  retryCount    Int       @default(0)
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  source     TrackedSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  subscriber EmailSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([sourceId, subscriberId, targetDate])
  @@index([status, targetDate])
  @@index([sourceId, targetDate])
}

model SubscriberDigestDelivery {
  id            String    @id @default(cuid())
  subscriberId  String
  targetDate    DateTime
  scheduledFor  DateTime
  status        String    @default("scheduled")
  subject       String
  emailId       String?
  itemCount     Int       @default(0)
  summary       String?
  failureReason String?
  retryCount    Int       @default(0)
  retryAfter    DateTime?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscriber EmailSubscriber                  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  sources    SubscriberDigestDeliverySource[]

  @@unique([subscriberId, targetDate])
  @@index([status, scheduledFor])
  @@index([targetDate, status])
}

model SubscriberDigestDeliverySource {
  id         String   @id @default(cuid())
  deliveryId String
  sourceId   String
  itemCount  Int      @default(0)
  createdAt  DateTime @default(now())

  delivery SubscriberDigestDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  source   TrackedSource            @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([deliveryId, sourceId])
  @@index([sourceId])
}

model SourceSubmission {
  id                String    @id @default(cuid())
  siteName          String
  siteUrl           String
  description       String
  contactEmail      String?
  requestedCategory String?
  status            String    @default("new")
  reviewNotes       String?
  reviewedBy        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  reviewedAt        DateTime?
  trackedSourceId   String?

  trackedSource TrackedSource? @relation(fields: [trackedSourceId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([siteUrl])
}

model FeedbackSubmission {
  id         String    @id @default(cuid())
  type       String    @default("general")
  message    String
  email      String?
  page       String?
  status     String    @default("new")
  adminNotes String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([status, createdAt])
  @@index([type, createdAt])
}
